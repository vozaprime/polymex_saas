generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id         String   @id @default(cuid())
  name       String
  coverImage String?
  gallery    String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
